# Normalize all text files to LF in the repo (Linux server expects LF)
* text=auto eol=lf

# Explicit binaries (don't normalize, don't diff as text)
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.tgz binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp3 binary
*.mp4 binary

# SQL files: treat as text (line-ending normalization)
*.sql text
