Options -Indexes

<FilesMatch "^(config\.php|config\.local\.php|config\.example\.php|bootstrap\.php|README-CPANEL\.md)$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://*.google-analytics.com; img-src 'self' data: https:; style-src 'self'; frame-src 'self' https://docs.google.com https://drive.google.com; form-action 'self'; frame-ancestors 'self'; base-uri 'self'"
</IfModule>
